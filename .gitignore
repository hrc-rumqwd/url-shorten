## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio 2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Generated files
Generated\ Files/

# Backup & report files
*.backup
*.bak
*.bkp
*.tmp
*.log
*.svclog
*.scc

# Visual Studio profiler
*.psess
*.vsp
*.vspx

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# DotCover
*.dotCover

# NCrunch
_NCrunch_*
.*crunch*.local.xml
ncrunchproject.local.xml

# MSTest test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Coverlet
coverage*.json
coverage*.xml
coverage*.info

# Azure Pipelines
*.azure-pipelines.yml

# Rider
.idea/
*.sln.iml

# VS Code directories
.vscode/

# Static analysis results
*.sarif

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.ipdb
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlh
*.tli
*.tmp
*.tmp_proj
*.log
*.tlog
*.vspscc
*_i.asm
*_p.asm
*.cachefile

# Others
*.dbmdl
*.dbproj.schemaview
*.jfm

# Local configs
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
appsettings.*.json
appsettings.json

# Entity Framework Migrations model snapshot conflicts
*_ModelSnapshot.cs

# Dotnet tools
**/.store/
**/.tools/
**/.tmp/

# Package directories
*.nupkg
*.snupkg
.nuget/

# Local NuGet packages
packages/
*.nuget.props
*.nuget.targets

# Dotnet dev certs
*.pfx

# Logs
logs/
*.log

# SQL Server
*.mdf
*.ldf

# IIS Express
iisexpress/
ApplicationHost.config

# Others
*.DS_Store
Thumbs.db
Desktop.ini
